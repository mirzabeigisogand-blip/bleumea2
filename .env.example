# ─────────────────────────────────────────────────────────────────────────────
# BLEUMEA — تنظیمات محیطی
# این فایل رو کپی کنید به .env و مقادیر رو پر کنید
# ─────────────────────────────────────────────────────────────────────────────

# پایگاه‌داده
# برای توسعه محلی (پیش‌فرض):
DATABASE_URL="file:./db/custom.db"

# برای production (Vercel) — از Turso استفاده کنید (رایگان):
# ۱. به https://turso.tech بروید و ثبت‌نام کنید
# ۲. یه database بسازید: turso db create bleumea
# ۳. URL رو بگیرید: turso db show bleumea --url
# ۴. توکن بسازید: turso db tokens create bleumea
# ۵. مقادیر زیر رو در Vercel Environment Variables تنظیم کنید:
# DATABASE_URL="libsql://bleumea-xxxx.turso.io"
# DATABASE_AUTH_TOKEN="eyJxxxxxxxxxxxx..."

# کلید احراز هویت Turso (فقط برای production)
DATABASE_AUTH_TOKEN=""

# ─────────────────────────────────────────────────────────────────────────────
# تنظیمات مدل زبانی برای ترجمهٔ شعری فارسی
# پیش‌فرض: GLM (智谱)
# می‌توانید بعداً از تنظیمات داخل سایت تغییر دهید
# ─────────────────────────────────────────────────────────────────────────────

# ارائه‌دهنده: glm | groq | openai | openrouter | together | ollama
LLM_PROVIDER="glm"

# کلید API
LLM_API_KEY=""

# آدرس پایه API
LLM_BASE_URL="https://open.bigmodel.cn/api/paas/v4"

# نام مدل
LLM_MODEL="glm-4.6"
